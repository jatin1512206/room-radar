rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'property_type', 'city', 'price_per_month'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.price_per_month is number
        && request.resource.data.price_per_month > 0;
      allow update, delete: if false;
    }
  }
}
